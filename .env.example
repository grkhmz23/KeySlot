# GORKH Wallet local environment
#
# RPC Fast tokens are local-only. Do not commit `.env`, paste tokens into chat,
# or place tokens in app source, UserDefaults, logs, audit, snapshots, or docs.
# Rotate any token that was pasted into a chat or shared in plaintext.

GORKH_RPCFAST_DEVNET_TOKEN=
GORKH_RPCFAST_MAINNET_TOKEN=

# Optional fallback names supported by the app:
# RPCFAST_DEVNET_TOKEN=
# RPCFAST_MAINNET_TOKEN=

# Jupiter API key remains optional and env-only.
# GORKH_JUPITER_API_KEY=

# Hosted Agent API remains env-only. The macOS app calls GORKH's hosted
# endpoint and never stores a provider API key.
GORKH_AGENT_API_BASE_URL=
# GORKH_AGENT_API_KEY=
